# Gemini AI (required for recommendations)
GEMINI_API_KEY=your_gemini_api_key

# TMDB - Movies & TV (required for movie/TV search)
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key

# Google Books (optional - fallback for richer book descriptions)
GOOGLE_BOOKS_API_KEY=your_google_books_key

# Google OAuth (required for login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Session secret (change this in production)
SECRET_KEY=change-this-to-a-random-string

# JWT secret for API token auth (Apple TV / mobile clients)
JWT_SECRET=change-this-to-a-different-random-string
